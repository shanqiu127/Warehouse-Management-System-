{
  "info": {
    "name": "Warehouse Management - Auth & Password",
    "description": "认证体系与密码设置接口集合（按 db.sql 口径：种子账号 superadmin/admin/employee，默认密码 ljs2005416LJS@）。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "superadminUsername",
      "value": "superadmin"
    },
    {
      "key": "adminUsername",
      "value": "admin"
    },
    {
      "key": "employeeUsername",
      "value": "employee"
    },
    {
      "key": "defaultPassword",
      "value": "ljs2005416LJS@"
    },
    {
      "key": "employeeUserId",
      "value": "2"
    },
    {
      "key": "newPassword",
      "value": "ljs2005416LJS@"
    }
  ],
  "item": [
    {
      "name": "登录",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const responseJson = pm.response.json();",
              "pm.test('登录成功', function () { pm.expect(responseJson.code).to.eql(200); });",
              "pm.test('返回 token', function () { pm.expect(responseJson.data).to.have.property('token'); });",
              "pm.collectionVariables.set('token', responseJson.data.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{defaultPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "注册(仅普通用户)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const responseJson = pm.response.json();",
              "pm.test('注册请求返回成功', function () { pm.expect(responseJson.code).to.eql(200); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"employee_new_demo\",\n  \"realName\": \"普通员工Demo\",\n  \"password\": \"{{defaultPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "获取当前用户信息",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/userinfo",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "userinfo"
          ]
        }
      }
    },
    {
      "name": "检查登录状态",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/check",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "check"
          ]
        }
      }
    },
    {
      "name": "设置用户密码(管理员/超管)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const responseJson = pm.response.json();",
              "pm.test('设置密码请求返回成功', function () { pm.expect(responseJson.code).to.eql(200); });"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"newPassword\": \"{{newPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/system/users/{{employeeUserId}}/password",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "system",
            "users",
            "{{employeeUserId}}",
            "password"
          ]
        }
      }
    },
    {
      "name": "用户登出",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/logout",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "logout"
          ]
        }
      }
    },
    {
      "name": "停用 employee 账号(管理员)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const responseJson = pm.response.json();",
              "pm.test('停用账号请求返回成功', function () { pm.expect(responseJson.code).to.eql(200); });"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": 0\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/system/users/{{employeeUserId}}/status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "system",
            "users",
            "{{employeeUserId}}",
            "status"
          ]
        }
      }
    },
    {
      "name": "停用账号登录验证(employee 应失败)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const responseJson = pm.response.json();",
              "pm.test('停用账号不应登录成功', function () { pm.expect(responseJson.code).to.not.eql(200); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{employeeUsername}}\",\n  \"password\": \"{{defaultPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "恢复 employee 账号(管理员)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const responseJson = pm.response.json();",
              "pm.test('恢复账号请求返回成功', function () { pm.expect(responseJson.code).to.eql(200); });"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/system/users/{{employeeUserId}}/status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "system",
            "users",
            "{{employeeUserId}}",
            "status"
          ]
        }
      }
    }
  ]
}